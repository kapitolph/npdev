#!/usr/bin/env bash
# npdev — NextPay Dev VPS CLI
# Self-contained — no repo clone needed after install.
# Config and machines live in ~/.npdev/

set -euo pipefail

NPDEV_VERSION="0.3.0"
GITHUB_REPO="kapitolph/dev-vps"
NPDEV_DIR="$HOME/.npdev"
CONFIG_FILE="$NPDEV_DIR/config"
MACHINES_FILE="$NPDEV_DIR/machines.yaml"

# ─── Helpers ──────────────────────────────────────────────────────────────────

die() { printf '\033[1;31mError: %s\033[0m\n' "$*" >&2; exit 1; }
info() { printf '\033[1;34m▸ %s\033[0m\n' "$*"; }
ok()   { printf '\033[1;32m  ✓ %s\033[0m\n' "$*"; }

validate_session_name() {
  [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]] || die "Session name must contain only letters, numbers, hyphens, and underscores."
}

# ─── Config ───────────────────────────────────────────────────────────────────

load_config() {
  if [[ ! -f "$MACHINES_FILE" ]]; then
    die "npdev not configured. Run: npdev update (or bash client/setup.sh from repo)"
  fi
}

# ─── Machine Selection ────────────────────────────────────────────────────────

get_machine_count() {
  awk '/^  - name:/ { count++ } END { print count+0 }' "$MACHINES_FILE"
}

get_machine_field() {
  local machine_name="$1" field="$2"
  awk -v name="$machine_name" -v field="$field" '
    /^  - name:/ { current = $3 }
    current == name && $1 == (field ":") { print $2 }
  ' "$MACHINES_FILE"
}

get_machine_names() {
  awk '/^  - name:/ { print $3 }' "$MACHINES_FILE"
}

select_machine() {
  local target="${NPDEV_MACHINE:-}"
  local count
  count=$(get_machine_count)

  if [[ $count -eq 0 ]]; then
    die "No machines defined in $MACHINES_FILE"
  fi

  if [[ -n "$target" ]]; then
    local host user
    host=$(get_machine_field "$target" "host")
    user=$(get_machine_field "$target" "user")
    [[ -n "$host" ]] || die "Machine '$target' not found in $MACHINES_FILE"
    MACHINE_NAME="$target"
    MACHINE_HOST="$host"
    MACHINE_USER="$user"
    return
  fi

  if [[ $count -eq 1 ]]; then
    MACHINE_NAME=$(get_machine_names | head -1)
    MACHINE_HOST=$(get_machine_field "$MACHINE_NAME" "host")
    MACHINE_USER=$(get_machine_field "$MACHINE_NAME" "user")
    return
  fi

  echo "Available machines:" >&2
  local i=1
  local names=()
  while IFS= read -r name; do
    local desc
    desc=$(awk -v n="$name" '
      /^  - name:/ { current = $3 }
      current == n && /description:/ { sub(/^[[:space:]]*description:[[:space:]]*"?/, ""); sub(/"$/, ""); print }
    ' "$MACHINES_FILE")
    printf "  %d) %s — %s\n" "$i" "$name" "$desc" >&2
    names+=("$name")
    ((i++))
  done < <(get_machine_names)

  printf "Select machine [1-%d]: " "${#names[@]}" >&2
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "Invalid selection"
  ((choice >= 1 && choice <= ${#names[@]})) || die "Selection out of range"

  MACHINE_NAME="${names[$((choice - 1))]}"
  MACHINE_HOST=$(get_machine_field "$MACHINE_NAME" "host")
  MACHINE_USER=$(get_machine_field "$MACHINE_NAME" "user")
}

ssh_target() {
  echo "$MACHINE_USER@$MACHINE_HOST"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
  local name="$1"; shift
  local desc="${*:-}"
  validate_session_name "$name"
  select_machine
  if [[ -n "$desc" ]]; then
    ssh -t "$(ssh_target)" "bash ~/.vps/session.sh start '$name' 'shell' '$desc'"
  else
    ssh -t "$(ssh_target)" "bash ~/.vps/session.sh start '$name' 'shell'"
  fi
}

cmd_list() {
  select_machine
  ssh "$(ssh_target)" "bash ~/.vps/session.sh list"
}

cmd_end() {
  local name="$1"
  validate_session_name "$name"
  select_machine
  ssh -t "$(ssh_target)" "bash ~/.vps/session.sh end '$name'"
}

cmd_shell() {
  select_machine
  ssh -t "$(ssh_target)" "exec \$SHELL -l"
}

cmd_sync_keys() {
  select_machine
  local target
  target="$(ssh_target)"

  echo "Fetching keys from GitHub (${GITHUB_REPO})..."

  local key_files
  key_files=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/contents/keys" 2>/dev/null \
    | grep '"name"' | grep '\.pub"' | sed 's/.*"name": "\(.*\)".*/\1/')

  if [[ -z "$key_files" ]]; then
    echo "No .pub files found in keys/ (or GitHub API error)."
    return 1
  fi

  local added=0
  for file in $key_files; do
    [[ "$file" == ".gitkeep" ]] && continue
    local name="${file%.pub}"
    local key
    key=$(curl -fsSL "https://raw.githubusercontent.com/${GITHUB_REPO}/main/keys/${file}" 2>/dev/null)
    [[ -z "$key" ]] && continue

    local result
    result=$(ssh "$target" "grep -qF '${key}' ~/.ssh/authorized_keys 2>/dev/null && echo 'exists' || { echo '${key}' >> ~/.ssh/authorized_keys && echo 'added'; }")

    if [[ "$result" == "added" ]]; then
      printf '  \033[1;32m✓ Added key: %s\033[0m\n' "$name"
      ((added++))
    else
      printf '  · Already present: %s\n' "$name"
    fi
  done

  if [[ $added -gt 0 ]]; then
    printf '\033[1;32m%d new key(s) synced to %s\033[0m\n' "$added" "$MACHINE_NAME"
  else
    echo "All keys already synced."
  fi
}

cmd_update() {
  info "Updating npdev from GitHub (${GITHUB_REPO})..."

  mkdir -p "$NPDEV_DIR"

  # Update machines.yaml
  local new_machines
  new_machines=$(curl -fsSL "https://raw.githubusercontent.com/${GITHUB_REPO}/main/machines.yaml" 2>/dev/null)
  if [[ -n "$new_machines" ]]; then
    echo "$new_machines" > "$MACHINES_FILE"
    ok "machines.yaml updated"
  else
    die "Failed to fetch machines.yaml from GitHub"
  fi

  # Update npdev script itself
  local self_path
  self_path="$(realpath "${BASH_SOURCE[0]}")"
  local new_script
  new_script=$(curl -fsSL "https://raw.githubusercontent.com/${GITHUB_REPO}/main/client/npdev" 2>/dev/null)
  if [[ -n "$new_script" ]]; then
    echo "$new_script" > "$self_path"
    chmod +x "$self_path"
    ok "npdev script updated"
  else
    die "Failed to fetch npdev from GitHub"
  fi

  local new_version
  new_version=$(grep '^NPDEV_VERSION=' "$self_path" | cut -d'"' -f2)
  ok "npdev is now at v${new_version:-unknown}"
}

cmd_usage() {
  cat <<'USAGE'
npdev — NextPay Dev VPS CLI

Usage:
  npdev                           Quick shell (no tmux session)
  npdev <session-name> [desc]     Create or attach to named tmux session
  npdev list                      List all sessions
  npdev end <session-name>        End a session
  npdev sync-keys                 Sync keys/*.pub from GitHub to VPS
  npdev update                    Update npdev + machines from GitHub
  npdev --machine <name> ...      Select VPS when multiple configured
  npdev --version                 Show version
  npdev --help                    Show this help

Pair programming:
  Two people running the same session name share the terminal.

Inside a session:
  Ctrl+B, D                       Detach (session stays alive)
USAGE
}

# ─── Main ─────────────────────────────────────────────────────────────────────

NPDEV_MACHINE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --machine)
      shift; NPDEV_MACHINE="${1:-}"; [[ -n "$NPDEV_MACHINE" ]] || die "--machine requires a name"
      shift ;;
    --version|-v)
      echo "npdev $NPDEV_VERSION"; exit 0 ;;
    --help|-h)
      cmd_usage; exit 0 ;;
    *)
      break ;;
  esac
done

# update doesn't need config
case "${1:-}" in
  update)
    cmd_update; exit 0 ;;
esac

load_config

case "${1:-}" in
  "")
    cmd_shell ;;
  list)
    cmd_list ;;
  sync-keys)
    cmd_sync_keys ;;
  end)
    shift; [[ $# -lt 1 ]] && die "Usage: npdev end <session-name>"
    cmd_end "$1" ;;
  --help|-h)
    cmd_usage ;;
  *)
    cmd_start "$@" ;;
esac
